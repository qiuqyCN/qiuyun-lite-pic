<!--filter.wxml-->
<view class="filter-container">
  <!-- 未选择图片状态 -->
  <image-upload
    wx:if="{{!hasImage}}"
    icon="✨"
    title="选择图片"
    hint="点击从相册选择或拍照"
    bind:upload="chooseImage"
  />

  <!-- 已选择图片 -->
  <view wx:else class="filter-layout">
    <!-- 图片预览区域 -->
    <image-preview
      imagePath="{{filteredPath}}"
      title="滤镜预览"
      showChange="{{true}}"
      isProcessing="{{isProcessing}}"
      processingText="处理中..."
      bind:change="chooseImage"
      bind:preview="previewImage"
    />

    <!-- 滤镜强度调节 -->
    <view wx:if="{{currentFilter !== 'original'}}" class="intensity-section">
      <slider-control
        label="滤镜强度"
        value="{{filterIntensity}}"
        min="0"
        max="100"
        unit="%"
        activeColor="#41bc3f"
        bind:change="onIntensityChange"
      />
    </view>

    <!-- 滤镜选择 -->
    <view class="filter-section">
      <scroll-selector
        title="选择滤镜"
        list="{{filterList}}"
        selectedId="{{currentFilter}}"
        showHint="{{true}}"
        hintText="左右滑动查看更多"
        bind:select="onFilterSelect"
      />
    </view>

    <!-- 输出格式 -->
    <format-selector
      value="{{fileType}}"
      mode="horizontal"
      showDesc="{{false}}"
      bind:change="onFormatChange"
    />

    <!-- 操作按钮：始终显示重置+保存 -->
    <action-buttons
      hasResult="{{true}}"
      isLoading="{{isProcessing}}"
      primaryText="保存到相册"
      secondaryText="重置"
      saveText="保存到相册"
      loadingText="处理中..."
      bind:primary="saveToAlbum"
      bind:secondary="resetFilter"
      bind:save="saveToAlbum"
    />
  </view>

  <!-- 隐藏Canvas -->
  <canvas
    type="2d"
    id="filterCanvas"
    class="hidden-canvas"
  ></canvas>

  <view class="safe-area-bottom"></view>
</view>

<!--filter.wxml-->
<view class="filter-container">
  <!-- 未选择图片状态 -->
  <view wx:if="{{!hasImage}}" class="upload-section">
    <view class="upload-card" bindtap="chooseImage">
      <view class="upload-icon-box">
        <text class="upload-icon">✨</text>
      </view>
      <text class="upload-title">选择图片</text>
      <text class="upload-hint">点击从相册选择或拍照</text>
    </view>
  </view>

  <!-- 已选择图片 -->
  <view wx:else class="filter-layout">
    <!-- 图片预览区域 -->
    <view class="preview-section">
      <view class="preview-header">
        <text class="preview-title">滤镜预览</text>
        <view class="change-btn" bindtap="chooseImage">
          <text>更换</text>
        </view>
      </view>

      <view class="preview-container">
        <image
          class="preview-image"
          src="{{filteredPath}}"
          mode="aspectFit"
          bindtap="previewImage"
          lazy-load="{{false}}"
        />
        <view wx:if="{{isProcessing}}" class="processing-mask">
          <text class="processing-text">处理中...</text>
        </view>
      </view>
    </view>

    <!-- 滤镜强度调节 -->
    <view wx:if="{{currentFilter !== 'none'}}" class="intensity-section">
      <view class="intensity-header">
        <text class="intensity-label">滤镜强度</text>
        <text class="intensity-value">{{filterIntensity}}%</text>
      </view>
      <slider
        class="intensity-slider"
        min="0"
        max="100"
        value="{{filterIntensity}}"
        block-size="24"
        activeColor="#41bc3f"
        backgroundColor="#e8e8ed"
        bindchange="onIntensityChange"
      />
    </view>

    <!-- 滤镜选择 -->
    <view class="filter-section">
      <view class="filter-section-header">
        <text class="filter-section-title">选择滤镜</text>
        <view class="scroll-hint">
          <text class="scroll-hint-text">左右滑动查看更多</text>
          <text class="scroll-hint-icon">→</text>
        </view>
      </view>
      <scroll-view class="filter-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}">
        <view class="filter-list">
          <view
            wx:for="{{filterList}}"
            wx:key="id"
            class="filter-item {{currentFilter === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="onFilterTap"
          >
            <view class="filter-icon">{{item.icon}}</view>
            <text class="filter-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <view class="action-row">
        <button class="btn btn-secondary btn-flex" bindtap="resetFilter">
          重置
        </button>
        <button class="btn btn-primary btn-flex" bindtap="saveToAlbum">
          保存到相册
        </button>
      </view>
    </view>
  </view>

  <!-- 隐藏Canvas -->
  <canvas
    type="2d"
    id="filterCanvas"
    class="hidden-canvas"
  ></canvas>

  <view class="safe-area-bottom"></view>
</view>

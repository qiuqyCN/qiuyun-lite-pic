<!--compress.wxml-->
<view class="compress-container">
  <!-- 未选择图片状态 -->
  <view wx:if="{{!hasImage}}" class="upload-section">
    <view class="upload-card" bindtap="chooseImage">
      <view class="upload-icon-box">
        <text class="upload-icon">+</text>
      </view>
      <text class="upload-title">选择图片</text>
      <text class="upload-hint">点击从相册选择或拍照</text>
    </view>
  </view>

  <!-- 已选择图片 -->
  <view wx:else class="compress-layout">
    <!-- 图片预览区域 -->
    <view class="preview-section">
      <view class="preview-header">
        <text class="preview-title">{{compressedPath ? '压缩完成' : '图片预览'}}</text>
        <view class="change-btn" bindtap="chooseImage">
          <text>更换</text>
        </view>
      </view>

      <view class="preview-container">
        <image
          class="preview-image"
          src="{{compressedPath || imagePath}}"
          mode="aspectFit"
          bindtap="previewImage"
        />
      </view>
    </view>

    <!-- 大小信息 -->
    <view class="size-section">
      <view wx:if="{{!compressedPath}}" class="size-info">
        <view class="size-row">
          <text class="size-label">当前</text>
          <text class="size-value">{{originalSize}} KB</text>
        </view>
        <view class="size-row estimated">
          <text class="size-label">预计</text>
          <text class="size-value-range">{{estimatedMin}} ~ {{estimatedMax}} KB</text>
        </view>
      </view>

      <view wx:else class="size-result">
        <view class="result-main">
          <text class="result-original">{{originalSize}} KB</text>
          <text class="result-arrow">→</text>
          <text class="result-actual">{{compressedSize}} KB</text>
        </view>
        <view class="result-badge">
          <text>节省 {{savedPercent}}%</text>
        </view>
      </view>
    </view>

    <!-- 压缩设置（压缩前显示） -->
    <view wx:if="{{!compressedPath}}" class="settings-section">
      <!-- 快速预设 -->
      <view class="presets-row">
        <view
          class="preset-btn {{quality === 30 ? 'active' : ''}}"
          data-quality="30"
          bindtap="onPresetTap"
        >
          <text class="preset-name">极速</text>
          <text class="preset-desc">30%</text>
        </view>
        <view
          class="preset-btn {{quality === 60 ? 'active' : ''}}"
          data-quality="60"
          bindtap="onPresetTap"
        >
          <text class="preset-name">均衡</text>
          <text class="preset-desc">60%</text>
        </view>
        <view
          class="preset-btn {{quality === 85 ? 'active' : ''}}"
          data-quality="85"
          bindtap="onPresetTap"
        >
          <text class="preset-name">高清</text>
          <text class="preset-desc">85%</text>
        </view>
      </view>

      <!-- 质量滑块 -->
      <view class="slider-control">
        <view class="slider-header">
          <text class="slider-label">压缩质量</text>
          <text class="slider-value">{{quality}}%</text>
        </view>
        <slider
          class="quality-slider"
          min="10"
          max="100"
          value="{{quality}}"
          block-size="24"
          activeColor="#0066ff"
          backgroundColor="#e8e8ed"
          bindchange="onQualityChange"
          bindchanging="onQualityChanging"
        />
        <view class="slider-hints">
          <text>体积小</text>
          <text>画质好</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <!-- 压缩前：开始压缩 -->
      <button
        wx:if="{{!compressedPath}}"
        class="btn btn-primary btn-lg btn-block {{isProcessing ? 'btn-loading' : ''}}"
        bindtap="startCompress"
        disabled="{{isProcessing}}"
      >
        <text wx:if="{{!isProcessing}}">开始压缩</text>
        <view wx:else class="loading-dots">
          <text>压缩中</text>
          <text class="dot">.</text>
          <text class="dot">.</text>
          <text class="dot">.</text>
        </view>
      </button>

      <!-- 压缩后：重新压缩 + 保存 -->
      <view wx:if="{{compressedPath}}" class="action-row">
        <button class="btn btn-secondary btn-flex" bindtap="resetCompress">
          重新压缩
        </button>
        <button class="btn btn-primary btn-flex" bindtap="saveToAlbum">
          保存到相册
        </button>
      </view>
    </view>
  </view>

  <!-- 隐藏Canvas -->
  <canvas
    type="2d"
    id="compressCanvas"
    class="hidden-canvas"
  ></canvas>

  <view class="safe-area-bottom"></view>
</view>

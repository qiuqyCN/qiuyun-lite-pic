<!--compress.wxml-->
<view class="compress-container">
  <!-- 未选择图片状态 -->
  <image-upload
    wx:if="{{!hasImage}}"
    icon="✨"
    title="选择图片"
    hint="点击从相册选择或拍照"
    bind:upload="chooseImage"
  />

  <!-- 已选择图片 -->
  <view wx:else class="compress-layout">
    <!-- 图片预览区域 -->
    <image-preview
      imagePath="{{compressedPath || imagePath}}"
      title="{{compressedPath ? '压缩完成' : '图片预览'}}"
      showChange="{{true}}"
      isProcessing="{{isProcessing}}"
      processingText="压缩中..."
      bind:change="chooseImage"
      bind:preview="previewImage"
    />

    <!-- 大小信息 -->
    <view class="size-section">
      <view class="size-info">
        <view class="size-row">
          <text class="size-label">原图</text>
          <text class="size-value">{{originalSize}} KB</text>
        </view>
        <view wx:if="{{compressedPath}}" class="size-row">
          <text class="size-label">压缩后</text>
          <text class="size-value" style="color: #41bc3f;">{{compressedSize}} KB</text>
        </view>
        <view wx:if="{{compressedPath && savedPercent > 0}}" class="result-badge">
          <text>节省 {{savedPercent}}%</text>
        </view>
      </view>
    </view>

    <!-- 压缩设置 -->
    <view class="settings-section">
      <!-- 快速预设 -->
      <view class="presets-row">
        <view
          class="preset-btn {{quality === 30 ? 'active' : ''}}"
          data-quality="30"
          bindtap="onPresetTap"
        >
          <text class="preset-name">极速</text>
          <text class="preset-desc">30%</text>
        </view>
        <view
          class="preset-btn {{quality === 60 ? 'active' : ''}}"
          data-quality="60"
          bindtap="onPresetTap"
        >
          <text class="preset-name">均衡</text>
          <text class="preset-desc">60%</text>
        </view>
        <view
          class="preset-btn {{quality === 85 ? 'active' : ''}}"
          data-quality="85"
          bindtap="onPresetTap"
        >
          <text class="preset-name">高清</text>
          <text class="preset-desc">85%</text>
        </view>
      </view>

      <!-- 质量滑块 -->
      <slider-control
        label="压缩质量"
        value="{{quality}}"
        min="10"
        max="100"
        unit="%"
        activeColor="#41bc3f"
        showHints="{{true}}"
        minHint="体积小"
        maxHint="画质好"
        bind:changing="onQualityChanging"
        bind:change="onQualityChange"
      />
    </view>

    <!-- 输出格式 -->
    <format-selector
      value="{{fileType}}"
      mode="horizontal"
      showDesc="{{false}}"
      disabledFormats="{{['png']}}"
      showTip="{{true}}"
      tipText="提示：压缩功能仅支持输出JPG格式。PNG为无损格式，无法通过调整质量来减小体积"
      bind:change="onFormatChange"
    />

    <!-- 操作按钮：始终显示重置+保存 -->
    <action-buttons
      hasResult="{{true}}"
      isLoading="{{isProcessing}}"
      primaryText="保存到相册"
      secondaryText="重置"
      saveText="保存到相册"
      loadingText="处理中..."
      bind:primary="saveToAlbum"
      bind:secondary="resetCompress"
      bind:save="saveToAlbum"
    />
  </view>

  <!-- 隐藏Canvas -->
  <canvas
    type="2d"
    id="compressCanvas"
    class="hidden-canvas"
  ></canvas>

  <view class="safe-area-bottom"></view>
</view>

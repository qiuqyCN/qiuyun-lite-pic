<!--compress.wxml-->
<view class="compress-container">
  <!-- 图片选择/预览区域 -->
  <view class="image-section">
    <!-- 未选择图片 -->
    <view wx:if="{{!hasImage}}" class="upload-area" bindtap="chooseImage">
      <view class="upload-placeholder">
        <view class="upload-icon-box">
          <text class="upload-icon">+</text>
        </view>
        <text class="upload-title">选择图片</text>
        <text class="upload-hint">点击从相册选择或拍照</text>
      </view>
    </view>

    <!-- 已选择图片 -->
    <view wx:else class="preview-area">
      <image class="preview-image" src="{{imagePath}}" mode="aspectFit" bindtap="previewImage"/>
      <view class="preview-overlay" bindtap="chooseImage">
        <text class="overlay-text">更换图片</text>
      </view>
    </view>
  </view>

  <!-- 图片信息 -->
  <view wx:if="{{hasImage}}" class="info-section">
    <view class="info-card">
      <view class="info-item">
        <text class="info-label">原始大小</text>
        <text class="info-value">{{originalSize}} KB</text>
      </view>
      <view class="info-divider"></view>
      <view class="info-item">
        <text class="info-label">尺寸</text>
        <text class="info-value">{{originalWidth}} × {{originalHeight}}</text>
      </view>
    </view>
  </view>

  <!-- 压缩设置 -->
  <view wx:if="{{hasImage}}" class="settings-section">
    <view class="section-title">压缩设置</view>

    <view class="setting-card">
      <!-- 质量滑块 -->
      <view class="setting-item">
        <view class="setting-header">
          <text class="setting-name">压缩质量</text>
          <text class="setting-badge">{{quality}}%</text>
        </view>
        <slider
          class="quality-slider"
          min="10"
          max="100"
          value="{{quality}}"
          block-size="28"
          activeColor="#0066ff"
          backgroundColor="#e8e8ed"
          bindchange="onQualityChange"
        />
        <view class="slider-hints">
          <text class="hint-text">体积小</text>
          <text class="hint-text">画质好</text>
        </view>
      </view>

      <!-- 目标大小 -->
      <view class="setting-item">
        <view class="setting-header">
          <text class="setting-name">目标大小</text>
          <text class="setting-optional">可选</text>
        </view>
        <view class="input-group">
          <input
            class="size-input"
            type="number"
            placeholder="不填则按质量压缩"
            value="{{targetSize > 0 ? targetSize : ''}}"
            bindinput="onTargetSizeInput"
          />
          <text class="input-unit">KB</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 压缩结果 -->
  <view wx:if="{{showResult}}" class="result-section">
    <view class="section-title">压缩结果</view>

    <view class="result-card">
      <view class="result-item">
        <view class="result-icon success">✓</view>
        <view class="result-content">
          <text class="result-label">压缩后大小</text>
          <text class="result-value">{{compressedSize}} KB</text>
        </view>
        <view class="result-badge saved">
          <text>节省 {{originalSize - compressedSize}} KB</text>
        </view>
      </view>

      <view class="progress-bar-container">
        <view class="progress-label">
          <text>压缩率</text>
          <text class="progress-percent">{{Math.round((originalSize - compressedSize) / originalSize * 100)}}%</text>
        </view>
        <view class="progress-track">
          <view class="progress-fill" style="width: {{Math.round((originalSize - compressedSize) / originalSize * 100)}}%"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view wx:if="{{hasImage}}" class="action-section">
    <button
      class="btn btn-primary btn-lg btn-block {{isProcessing ? 'btn-loading' : ''}}"
      bindtap="startCompress"
      disabled="{{isProcessing}}"
    >
      <text wx:if="{{!isProcessing}}">开始压缩</text>
      <view wx:else class="loading-dots">
        <text>压缩中</text>
        <text class="dot">.</text>
        <text class="dot">.</text>
        <text class="dot">.</text>
      </view>
    </button>

    <button
      wx:if="{{showResult}}"
      class="btn btn-secondary btn-lg btn-block"
      bindtap="saveToAlbum"
    >
      保存到相册
    </button>
  </view>

  <!-- 隐藏Canvas -->
  <canvas
    type="2d"
    id="compressCanvas"
    class="hidden-canvas"
  ></canvas>

  <view class="safe-area-bottom"></view>
</view>

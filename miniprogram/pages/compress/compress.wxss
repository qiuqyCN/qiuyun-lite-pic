/**compress.wxss**/
/* 现代极简风 - 图片压缩页面 */

.compress-container {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 20px;
  box-sizing: border-box;
}

/* 图片选择/预览区域 */
.image-section {
  margin-bottom: 16px;
}

/* 上传区域 */
.upload-area {
  background: #ffffff;
  border-radius: 20px;
  border: 2px dashed #d2d2d7;
  padding: 48px 24px;
  transition: all 0.2s ease;
}

.upload-area:active {
  border-color: #0066ff;
  background: #f8f9ff;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.upload-icon-box {
  width: 72px;
  height: 72px;
  background: #f5f5f7;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.upload-icon {
  font-size: 32px;
  color: #86868b;
  font-weight: 300;
}

.upload-title {
  font-size: 18px;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 6px;
}

.upload-hint {
  font-size: 14px;
  color: #86868b;
}

/* 预览区域 */
.preview-area {
  position: relative;
  background: #ffffff;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.preview-image {
  width: 100%;
  height: 240px;
  display: block;
}

.preview-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  padding: 40px 16px 16px;
  display: flex;
  justify-content: center;
}

.overlay-text {
  color: white;
  font-size: 14px;
  font-weight: 500;
  padding: 8px 20px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20px;
  backdrop-filter: blur(10px);
}

/* 图片信息 */
.info-section {
  margin-bottom: 20px;
}

.info-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.info-label {
  font-size: 12px;
  color: #86868b;
}

.info-value {
  font-size: 16px;
  font-weight: 600;
  color: #1d1d1f;
}

.info-divider {
  width: 1px;
  height: 32px;
  background: #e8e8ed;
}

/* 设置区域 */
.settings-section {
  margin-bottom: 20px;
}

.section-title {
  font-size: 13px;
  font-weight: 600;
  color: #86868b;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 12px;
  padding-left: 4px;
}

.setting-card {
  background: #ffffff;
  border-radius: 20px;
  padding: 20px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
}

.setting-item {
  margin-bottom: 24px;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.setting-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.setting-name {
  font-size: 15px;
  font-weight: 600;
  color: #1d1d1f;
}

.setting-badge {
  font-size: 14px;
  font-weight: 600;
  color: #0066ff;
  background: #e8f2ff;
  padding: 4px 12px;
  border-radius: 12px;
}

.setting-optional {
  font-size: 12px;
  color: #86868b;
  background: #f5f5f7;
  padding: 4px 10px;
  border-radius: 10px;
}

/* 滑块 */
.quality-slider {
  margin: 0;
}

.slider-hints {
  display: flex;
  justify-content: space-between;
  margin-top: 8px;
}

.hint-text {
  font-size: 12px;
  color: #86868b;
}

/* 输入框 */
.input-group {
  display: flex;
  align-items: center;
  background: #f5f5f7;
  border-radius: 12px;
  padding: 0 16px;
  height: 48px;
}

.size-input {
  flex: 1;
  height: 100%;
  font-size: 16px;
  color: #1d1d1f;
  background: transparent;
  border: none;
}

.size-input::placeholder {
  color: #c7c7cc;
}

.input-unit {
  font-size: 14px;
  color: #86868b;
  margin-left: 8px;
}

/* 结果区域 */
.result-section {
  margin-bottom: 20px;
}

.result-card {
  background: #ffffff;
  border-radius: 20px;
  padding: 20px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
}

.result-item {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

.result-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 600;
}

.result-icon.success {
  background: #e8f5e9;
  color: #34c759;
}

.result-content {
  flex: 1;
}

.result-label {
  font-size: 13px;
  color: #86868b;
  display: block;
  margin-bottom: 2px;
}

.result-value {
  font-size: 20px;
  font-weight: 700;
  color: #1d1d1f;
}

.result-badge {
  padding: 6px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 600;
}

.result-badge.saved {
  background: #e8f5e9;
  color: #34c759;
}

/* 进度条 */
.progress-bar-container {
  padding-top: 16px;
  border-top: 1px solid #f0f0f0;
}

.progress-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.progress-label text {
  font-size: 13px;
  color: #86868b;
}

.progress-percent {
  font-weight: 600;
  color: #0066ff !important;
}

.progress-track {
  height: 8px;
  background: #f0f0f0;
  border-radius: 4px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0066ff, #34c759);
  border-radius: 4px;
  transition: width 0.3s ease;
}

/* 操作按钮 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px 24px;
  font-size: 16px;
  font-weight: 600;
  border-radius: 16px;
  border: none;
  transition: all 0.2s ease;
}

.btn:active {
  transform: scale(0.98);
}

.btn-lg {
  padding: 18px 28px;
  font-size: 17px;
}

.btn-block {
  width: 100%;
}

.btn-primary {
  background: #0066ff;
  color: white;
  box-shadow: 0 4px 12px rgba(0, 102, 255, 0.3);
}

.btn-primary:active {
  background: #0052cc;
}

.btn-secondary {
  background: #f5f5f7;
  color: #1d1d1f;
}

.btn-secondary:active {
  background: #e8e8ed;
}

.btn-loading {
  opacity: 0.8;
}

/* 加载动画 */
.loading-dots {
  display: flex;
  align-items: center;
  gap: 2px;
}

.dot {
  animation: dot-blink 1.4s infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dot-blink {
  0%, 60%, 100% { opacity: 0; }
  30% { opacity: 1; }
}

/* 隐藏Canvas */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

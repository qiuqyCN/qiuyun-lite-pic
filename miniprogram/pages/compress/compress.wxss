/**compress.wxss**/
/* shadcn/ui 风格压缩页面 */

.page-container {
  min-height: 100vh;
  background: var(--bg-secondary);
  padding: 16px;
  box-sizing: border-box;
}

/* Upload Section */
.upload-section {
  margin-bottom: 24px;
}

.upload-card {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  border: 2px dashed var(--border-color);
  padding: 48px 24px;
  text-align: center;
  transition: all 0.15s ease;
}

.upload-card:active {
  border-color: var(--text-primary);
  background: var(--bg-muted);
}

.upload-icon-wrapper {
  width: 64px;
  height: 64px;
  background: var(--bg-muted);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16px;
}

.upload-icon {
  font-size: 32px;
  color: var(--text-secondary);
  font-weight: 300;
}

.upload-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4px;
}

.upload-description {
  font-size: 14px;
  color: var(--text-muted);
  display: block;
}

/* Preview Card */
.preview-card {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  border: 1px solid var(--border-color);
  overflow: hidden;
  box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
}

.preview-image {
  width: 100%;
  height: 280px;
  background: var(--bg-muted);
}

.preview-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-top: 1px solid var(--border-color);
}

.info-text {
  font-size: 14px;
  color: var(--text-secondary);
}

/* Section */
.section {
  margin-bottom: 24px;
}

.section-header {
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.025em;
}

/* Settings Card */
.settings-card {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  border: 1px solid var(--border-color);
  padding: 20px;
  box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
}

.setting-item {
  margin-bottom: 20px;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.setting-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.setting-label {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary);
}

.setting-value {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.quality-slider {
  margin: 0;
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8px;
}

.slider-label {
  font-size: 12px;
  color: var(--text-muted);
}

.separator {
  height: 1px;
  background: var(--border-color);
  margin: 20px 0;
}

.input-wrapper {
  position: relative;
  margin-top: 8px;
}

.input-suffix {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 14px;
  color: var(--text-muted);
}

/* Result Card */
.result-card {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  border: 1px solid var(--border-color);
  padding: 16px;
  box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--border-color);
}

.result-row:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 14px;
  color: var(--text-secondary);
}

.result-value {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.result-success {
  color: #16a34a;
}

/* Action Section */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.btn-disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Hidden Canvas */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}

/* Safe Area */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

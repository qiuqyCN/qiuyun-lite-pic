/* annotate.wxss */
/* 图片标注/涂鸦页面样式 */

.container {
  padding: 20rpx 30rpx;
  padding-bottom: 200rpx;
}

/* 区块样式 */
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 24rpx;
}

/* 涂鸦画布 */
.annotate-canvas {
  width: 100%;
  height: 400rpx;
  background: #f5f5f7;
  border-radius: 12rpx;
}

.canvas-hint {
  text-align: center;
  font-size: 24rpx;
  color: #86868b;
  margin-top: 16rpx;
}

/* 颜色选择 */
.color-section {
  margin-bottom: 24rpx;
}

.setting-label {
  font-size: 28rpx;
  color: #1d1d1f;
  margin-bottom: 16rpx;
  display: block;
}

.color-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.color-item.active {
  border-color: #41bc3f;
}

.color-check {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

/* 画笔大小 */
.size-section {
  margin-top: 24rpx;
}

.size-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.size-value {
  font-size: 26rpx;
  color: #41bc3f;
  font-weight: 500;
}

.size-slider {
  margin: 0;
}

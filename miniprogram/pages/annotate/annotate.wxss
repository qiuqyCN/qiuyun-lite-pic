/* annotate.wxss */
/* 图片标注/涂鸦页面样式 */

.container {
  padding: 20rpx 30rpx;
  padding-bottom: 200rpx;
}

/* 区块样式 */
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.annotate-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 24rpx;
}

/* 涂鸦画布 */
.canvas-container {
  background: #f5f5f7;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.annotate-canvas {
  display: block;
}

.canvas-hint {
  text-align: center;
  font-size: 24rpx;
  color: #86868b;
  margin-top: 16rpx;
}

/* 画笔类型选择 */
.brush-type-section {
  margin-bottom: 24rpx;
}

.brush-type-list {
  display: flex;
  gap: 16rpx;
}

.brush-type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 16rpx;
  background: #f5f5f7;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.brush-type-item.active {
  background: rgba(65, 188, 63, 0.1);
  border-color: #41bc3f;
}

.type-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.type-label {
  font-size: 24rpx;
  color: #1d1d1f;
}

.brush-type-item.active .type-label {
  color: #41bc3f;
  font-weight: 500;
}

/* 工具选择 */
.tool-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.tool-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #f5f5f7;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tool-item.active {
  background: rgba(65, 188, 63, 0.1);
  border-color: #41bc3f;
}

.tool-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tool-label {
  font-size: 26rpx;
  color: #1d1d1f;
}

.tool-item.active .tool-label {
  color: #41bc3f;
  font-weight: 500;
}

/* 颜色选择 */
.color-section {
  margin-bottom: 24rpx;
}

.color-scroll {
  white-space: nowrap;
}

.setting-label {
  font-size: 28rpx;
  color: #1d1d1f;
  margin-bottom: 16rpx;
  display: block;
}

.color-list {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 16rpx;
  padding-right: 30rpx;
}

.color-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.color-item.active {
  border-color: #41bc3f;
}

.color-check {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

/* 画笔大小 */
.size-section {
  margin-top: 24rpx;
}

.size-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.size-value {
  font-size: 26rpx;
  color: #41bc3f;
  font-weight: 500;
}

.size-slider {
  margin: 0;
}

<!--watermark.wxml-->
<view class="watermark-container">
  <!-- 未选择图片状态 -->
  <view wx:if="{{!hasImage}}" class="upload-section">
    <view class="upload-card" bindtap="chooseImage">
      <view class="upload-icon-box">
        <text class="upload-icon">💧</text>
      </view>
      <text class="upload-title">选择图片</text>
      <text class="upload-hint">点击从相册选择或拍照</text>
    </view>
  </view>

  <!-- 已选择图片 -->
  <view wx:else class="watermark-layout">
    <!-- 图片预览区域 -->
    <view class="preview-section">
      <view class="preview-header">
        <text class="preview-title">水印预览</text>
        <view class="change-btn" bindtap="chooseImage">
          <text>更换</text>
        </view>
      </view>

      <view class="preview-container">
        <image
          class="preview-image"
          src="{{watermarkedPath}}"
          mode="aspectFit"
          bindtap="previewImage"
          lazy-load="{{false}}"
        />
        <view wx:if="{{isProcessing}}" class="processing-mask">
          <text class="processing-text">处理中...</text>
        </view>
      </view>
    </view>

    <!-- 水印类型切换 -->
    <view class="type-section">
      <view class="type-tabs">
        <view
          class="type-tab {{watermarkType === 'text' ? 'active' : ''}}"
          data-type="text"
          bindtap="onTypeChange"
        >
          <text>文字水印</text>
        </view>
        <view
          class="type-tab {{watermarkType === 'image' ? 'active' : ''}}"
          data-type="image"
          bindtap="onTypeChange"
        >
          <text>图片水印</text>
        </view>
      </view>
    </view>

    <!-- 文字水印设置 -->
    <view wx:if="{{watermarkType === 'text'}}" class="settings-section">
      <!-- 文字输入 -->
      <view class="input-group">
        <text class="input-label">水印文字</text>
        <input
          class="text-input"
          type="text"
          value="{{watermarkText}}"
          placeholder="请输入水印文字"
          bindinput="onTextInput"
        />
      </view>

      <!-- 颜色选择 -->
      <view class="color-group">
        <text class="input-label">文字颜色</text>
        <view class="color-list">
          <view
            wx:for="{{colorList}}"
            wx:key="*this"
            class="color-item {{fontColor === item ? 'active' : ''}}"
            style="background-color: {{item}};"
            data-color="{{item}}"
            bindtap="onColorSelect"
          />
        </view>
      </view>

      <!-- 字体大小 -->
      <view class="slider-group">
        <view class="slider-header">
          <text class="slider-label">字体大小</text>
          <text class="slider-value">{{fontSize}}px</text>
        </view>
        <slider
          min="20"
          max="100"
          value="{{fontSize}}"
          block-size="24"
          activeColor="#0066ff"
          backgroundColor="#e8e8ed"
          bindchange="onFontSizeChange"
        />
      </view>

      <!-- 旋转角度 -->
      <view class="slider-group">
        <view class="slider-header">
          <text class="slider-label">旋转角度</text>
          <text class="slider-value">{{rotation}}°</text>
        </view>
        <slider
          min="0"
          max="360"
          value="{{rotation}}"
          block-size="24"
          activeColor="#0066ff"
          backgroundColor="#e8e8ed"
          bindchange="onRotationChange"
        />
      </view>
    </view>

    <!-- 图片水印设置 -->
    <view wx:if="{{watermarkType === 'image'}}" class="settings-section">
      <view class="image-watermark-section">
        <text class="input-label">选择水印图片</text>
        <view
          wx:if="{{!watermarkImage}}"
          class="select-image-btn"
          bindtap="chooseWatermarkImage"
        >
          <text class="select-icon">+</text>
          <text class="select-text">选择图片</text>
        </view>
        <view
          wx:else
          class="watermark-preview"
          bindtap="chooseWatermarkImage"
        >
          <image class="watermark-thumb" src="{{watermarkImage}}" mode="aspectFit" />
          <text class="change-text">点击更换</text>
        </view>
      </view>
    </view>

    <!-- 透明度设置（共用） -->
    <view class="settings-section">
      <view class="slider-group">
        <view class="slider-header">
          <text class="slider-label">透明度</text>
          <text class="slider-value">{{opacity}}%</text>
        </view>
        <slider
          min="10"
          max="100"
          value="{{opacity}}"
          block-size="24"
          activeColor="#0066ff"
          backgroundColor="#e8e8ed"
          bindchange="onOpacityChange"
        />
      </view>

      <!-- 位置选择 -->
      <view class="position-group">
        <text class="input-label">水印位置</text>
        <view class="position-grid">
          <view
            class="position-item {{position === 'topLeft' ? 'active' : ''}}"
            data-position="topLeft"
            bindtap="onPositionSelect"
          >
            <text>左上</text>
          </view>
          <view
            class="position-item {{position === 'topRight' ? 'active' : ''}}"
            data-position="topRight"
            bindtap="onPositionSelect"
          >
            <text>右上</text>
          </view>
          <view
            class="position-item {{position === 'center' ? 'active' : ''}}"
            data-position="center"
            bindtap="onPositionSelect"
          >
            <text>居中</text>
          </view>
          <view
            class="position-item {{position === 'bottomLeft' ? 'active' : ''}}"
            data-position="bottomLeft"
            bindtap="onPositionSelect"
          >
            <text>左下</text>
          </view>
          <view
            class="position-item {{position === 'bottomRight' ? 'active' : ''}}"
            data-position="bottomRight"
            bindtap="onPositionSelect"
          >
            <text>右下</text>
          </view>
          <view
            class="position-item {{position === 'tile' ? 'active' : ''}}"
            data-position="tile"
            bindtap="onPositionSelect"
          >
            <text>平铺</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <button class="btn btn-primary btn-lg btn-block" bindtap="saveToAlbum">
        保存到相册
      </button>
    </view>
  </view>

  <!-- 隐藏Canvas -->
  <canvas
    type="2d"
    id="watermarkCanvas"
    class="hidden-canvas"
  ></canvas>

  <view class="safe-area-bottom"></view>
</view>

<!--watermark.wxml-->
<view class="watermark-container">
  <!-- 未选择图片状态 -->
  <image-upload
    wx:if="{{!hasImage}}"
    icon="💧"
    title="选择图片"
    hint="点击从相册选择或拍照"
    bind:upload="chooseImage"
  />

  <!-- 已选择图片 -->
  <view wx:else class="watermark-layout">
    <!-- 图片预览区域 -->
    <image-preview
      imagePath="{{watermarkedPath}}"
      title="水印预览"
      showChange="{{true}}"
      isProcessing="{{isProcessing}}"
      processingText="处理中..."
      bind:change="chooseImage"
      bind:preview="previewImage"
    />

    <!-- 水印类型切换 -->
    <view class="type-section">
      <view class="type-tabs">
        <view
          class="type-tab {{watermarkType === 'text' ? 'active' : ''}}"
          data-type="text"
          bindtap="onTypeChange"
        >
          <text>文字水印</text>
        </view>
        <view
          class="type-tab {{watermarkType === 'image' ? 'active' : ''}}"
          data-type="image"
          bindtap="onTypeChange"
        >
          <text>图片水印</text>
        </view>
      </view>
    </view>

    <!-- 文字水印设置 -->
    <view wx:if="{{watermarkType === 'text'}}" class="settings-section">
      <!-- 文字输入 -->
      <view class="input-group">
        <text class="input-label">水印文字</text>
        <input
          class="text-input"
          type="text"
          value="{{watermarkText}}"
          placeholder="请输入水印文字"
          bindinput="onTextInput"
        />
      </view>

      <!-- 颜色选择 -->
      <color-picker
        title="文字颜色"
        colors="{{colorList}}"
        selectedColor="{{fontColor}}"
        bind:select="onColorSelect"
      />

      <!-- 字体大小 -->
      <slider-control
        label="字体大小"
        value="{{fontSize}}"
        min="20"
        max="100"
        unit="px"
        activeColor="#41bc3f"
        bind:change="onFontSizeChange"
      />

      <!-- 旋转角度 -->
      <slider-control
        label="旋转角度"
        value="{{rotation}}"
        min="0"
        max="360"
        unit="°"
        activeColor="#41bc3f"
        bind:change="onRotationChange"
      />
    </view>

    <!-- 图片水印设置 -->
    <view wx:if="{{watermarkType === 'image'}}" class="settings-section">
      <view class="image-watermark-section">
        <text class="input-label">选择水印图片</text>
        <view
          wx:if="{{!watermarkImage}}"
          class="select-image-btn"
          bindtap="chooseWatermarkImage"
        >
          <text class="select-icon">+</text>
          <text class="select-text">选择图片</text>
        </view>
        <view
          wx:else
          class="watermark-preview"
          bindtap="chooseWatermarkImage"
        >
          <image class="watermark-thumb" src="{{watermarkImage}}" mode="aspectFit" />
          <text class="change-text">点击更换</text>
        </view>
      </view>
    </view>

    <!-- 透明度设置（共用） -->
    <view class="settings-section">
      <slider-control
        label="透明度"
        value="{{opacity}}"
        min="10"
        max="100"
        unit="%"
        activeColor="#41bc3f"
        bind:change="onOpacityChange"
      />

      <!-- 位置选择 -->
      <view class="position-group">
        <text class="input-label">水印位置</text>
        <view class="position-grid">
          <view
            class="position-item {{position === 'topLeft' ? 'active' : ''}}"
            data-position="topLeft"
            bindtap="onPositionSelect"
          >
            <text>左上</text>
          </view>
          <view
            class="position-item {{position === 'topRight' ? 'active' : ''}}"
            data-position="topRight"
            bindtap="onPositionSelect"
          >
            <text>右上</text>
          </view>
          <view
            class="position-item {{position === 'center' ? 'active' : ''}}"
            data-position="center"
            bindtap="onPositionSelect"
          >
            <text>居中</text>
          </view>
          <view
            class="position-item {{position === 'bottomLeft' ? 'active' : ''}}"
            data-position="bottomLeft"
            bindtap="onPositionSelect"
          >
            <text>左下</text>
          </view>
          <view
            class="position-item {{position === 'bottomRight' ? 'active' : ''}}"
            data-position="bottomRight"
            bindtap="onPositionSelect"
          >
            <text>右下</text>
          </view>
          <view
            class="position-item {{position === 'tile' ? 'active' : ''}}"
            data-position="tile"
            bindtap="onPositionSelect"
          >
            <text>平铺</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 输出格式 -->
    <format-selector
      value="{{fileType}}"
      mode="horizontal"
      showDesc="{{false}}"
      bind:change="onFormatChange"
    />

    <!-- 操作按钮 -->
    <action-buttons
      hasResult="{{hasImage}}"
      isLoading="{{isProcessing}}"
      primaryText="保存到相册"
      secondaryText="重置"
      saveText="保存到相册"
      loadingText="处理中..."
      bind:primary="saveToAlbum"
      bind:secondary="resetWatermark"
      bind:save="saveToAlbum"
    />
  </view>

  <!-- 隐藏Canvas -->
  <canvas
    type="2d"
    id="watermarkCanvas"
    class="hidden-canvas"
  ></canvas>

  <view class="safe-area-bottom"></view>
</view>

/* pages/signature/signature.wxss */
.page-container {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 24rpx;
}

.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 画布区域 */
.canvas-card {
  padding: 0;
  overflow: hidden;
}

.canvas-container {
  position: relative;
  width: 100%;
  height: 360rpx;
  background: #f9f9f9;
  border-radius: 20rpx;
  border: 2rpx dashed #e5e5e5;
}

.signature-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.canvas-placeholder {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 0;
}

.placeholder-text {
  font-size: 30rpx;
  color: #c7c7cc;
  letter-spacing: 4rpx;
}

/* 操作按钮 */
.action-card {
  padding: 16rpx 24rpx;
}

.action-row {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
}

.action-btn:active {
  opacity: 0.6;
}

.action-icon {
  font-size: 40rpx;
}

.action-label {
  font-size: 22rpx;
  color: #86868b;
}

/* 颜色设置 - 与标注涂鸦一致 */
.setting-row {
  padding: 8rpx 0;
}

.setting-label {
  font-size: 28rpx;
  color: #1d1d1f;
  font-weight: 500;
}

.color-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 16rpx;
}

.color-list {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 16rpx;
  padding: 8rpx 0;
}

.color-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.color-item.active {
  border-color: #41bc3f;
}

.color-check {
  font-size: 24rpx;
  color: #fff;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
  font-weight: bold;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 16rpx 0;
}

/* 粗细设置 */
.size-section {
  padding: 8rpx 0;
}

.size-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.size-value {
  font-size: 26rpx;
  color: #41bc3f;
  font-weight: 500;
}

.size-slider {
  width: 100%;
  margin: 0;
}

/* 按钮区域 */
.btn-row {
  display: flex;
  gap: 24rpx;
  padding: 0 4rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  transition: opacity 0.2s ease;
}

.btn:active {
  opacity: 0.8;
}

.btn-reset {
  background: #fff;
  color: #86868b;
  border: 2rpx solid #e5e5e5;
}

.btn-save {
  background: #41bc3f;
  color: #fff;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* Safe Area */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

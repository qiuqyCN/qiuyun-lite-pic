<!--pages/signature/signature.wxml-->
<view class="page-container">
  <!-- 签名画布 -->
  <view class="section">
    <view class="section-card canvas-card">
      <view class="canvas-container" catchtouchstart="onTouchStart" catchtouchmove="onTouchMove" catchtouchend="onTouchEnd">
        <canvas type="2d" id="signatureCanvas" class="signature-canvas"></canvas>
        <view class="canvas-placeholder" wx:if="{{!hasSignature}}">
          <text class="placeholder-text">请在此处签名</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="section">
    <view class="section-card action-card">
      <view class="action-row">
        <view class="action-btn" bindtap="undo">
          <text class="action-icon">↩</text>
          <text class="action-label">撤销</text>
        </view>
        <view class="action-btn" bindtap="clearCanvas">
          <text class="action-icon">🗑</text>
          <text class="action-label">清空</text>
        </view>
        <view class="action-btn" bindtap="redo">
          <text class="action-icon">↪</text>
          <text class="action-label">重做</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 颜色设置 -->
  <view class="section">
    <view class="section-card">
      <view class="setting-row">
        <text class="setting-label">笔触颜色</text>
      </view>
      <scroll-view scroll-x class="color-scroll">
        <view class="color-list">
          <view
            wx:for="{{presetColors}}"
            wx:key="*this"
            class="color-item {{penColor === item ? 'active' : ''}}"
            style="background-color: {{item}};"
            data-color="{{item}}"
            bindtap="onColorSelect"
          >
            <text wx:if="{{penColor === item}}" class="color-check">✓</text>
          </view>
        </view>
      </scroll-view>

      <view class="divider"></view>

      <!-- 粗细设置 -->
      <view class="size-section">
        <view class="size-header">
          <text class="setting-label">笔触粗细</text>
          <text class="size-value">{{lineWidth}}px</text>
        </view>
        <slider
          class="size-slider"
          min="1"
          max="20"
          value="{{lineWidth}}"
          block-size="24"
          activeColor="#41bc3f"
          backgroundColor="#e8e8ed"
          bindchange="onLineWidthChange"
        />
      </view>
    </view>
  </view>

  <!-- 输出格式 -->
  <view class="section">
    <format-selector
      value="{{fileType}}"
      showDesc="{{false}}"
      disabledFormats="{{['jpg']}}"
      bind:change="onFormatChange"
    ></format-selector>
  </view>

  <!-- 提示信息 -->
  <view class="section">
    <view class="tips-card">
      <view class="tip-item">
        <text class="tip-icon">✅</text>
        <text class="tip-text">仅支持导出为 PNG 格式（透明背景）</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon">🚫</text>
        <text class="tip-text">不支持导出 JPG 格式</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="section">
    <action-buttons
  isLoading="{{isSaving}}"
  filePath="{{_cachedExportPath}}"
  disabled="{{!hasSignature}}"
  bind:reset="resetSignature"
  bind:save="saveToAlbum"
  bind:aftersave="onAfterSave"
/>
  </view>

  <view class="safe-area-bottom"></view>
</view>

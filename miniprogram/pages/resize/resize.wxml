<!--resize.wxml-->
<view class="resize-container">
  <!-- 未选择图片状态 -->
  <view wx:if="{{!hasImage}}" class="upload-section">
    <view class="upload-card" bindtap="chooseImage">
      <view class="upload-icon-box">
        <text class="upload-icon">📐</text>
      </view>
      <text class="upload-title">选择图片</text>
      <text class="upload-hint">支持证件照、考试报名等常用尺寸</text>
    </view>
  </view>

  <!-- 已选择图片 -->
  <view wx:else class="resize-layout">
    <!-- 图片预览区域（带尺寸标注） -->
    <view class="preview-section">
      <view class="preview-header">
        <text class="preview-title">尺寸预览</text>
        <view class="change-btn" bindtap="chooseImage">
          <text>更换</text>
        </view>
      </view>

      <view class="preview-with-dimensions">
        <view class="preview-main">
          <!-- 高度标注（在图片左侧） -->
          <view class="dimension-height-wrapper">
            <view class="dimension-height" style="height: {{previewDisplayHeight}}px;">
              <view class="dimension-line-v"></view>
              <text class="dimension-text-v">{{targetHeight}} px</text>
              <view class="dimension-line-v"></view>
            </view>
          </view>

          <view class="preview-content">
            <!-- 宽度标注（在图片上方） -->
            <view class="dimension-width" style="width: {{previewDisplayWidth}}px;">
              <view class="dimension-line"></view>
              <text class="dimension-text">{{targetWidth}} px</text>
              <view class="dimension-line"></view>
            </view>

            <!-- 图片容器 -->
            <view class="preview-container" style="width: {{previewDisplayWidth}}px; height: {{previewDisplayHeight}}px;">
              <image
                wx:if="{{previewPath}}"
                class="preview-image"
                src="{{previewPath}}"
                mode="aspectFit"
              />
              <view wx:if="{{!previewPath}}" class="preview-loading">
                <text>生成预览中...</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 尺寸预设选择（横向滑动） -->
    <view class="preset-section">
      <view class="preset-section-header">
        <text class="preset-section-title">常用尺寸</text>
        <view class="scroll-hint">
          <text class="scroll-hint-text">左右滑动查看更多</text>
          <text class="scroll-hint-icon">→</text>
        </view>
      </view>
      <scroll-view class="preset-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}">
        <view class="preset-list">
          <view
            wx:for="{{presetSizes}}"
            wx:key="id"
            class="preset-item {{selectedPreset === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="onPresetSelect"
          >
            <text class="preset-name">{{item.name}}</text>
            <text class="preset-size">{{item.width}}×{{item.height}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 自定义尺寸 -->
    <view class="custom-section">
      <view class="custom-header">
        <text class="custom-title">自定义尺寸</text>
        <view class="aspect-ratio-toggle">
          <text class="toggle-label">锁定比例</text>
          <switch
            class="toggle-switch"
            checked="{{maintainAspectRatio}}"
            bindchange="onAspectRatioChange"
            color="var(--accent)"
          />
        </view>
      </view>

      <view class="dimension-inputs">
        <view class="input-group">
          <text class="input-label">宽度</text>
          <input
            class="dimension-input"
            type="number"
            value="{{targetWidth}}"
            bindinput="onWidthInput"
            placeholder="宽度"
          />
          <text class="input-unit">px</text>
        </view>

        <view class="dimension-separator">×</view>

        <view class="input-group">
          <text class="input-label">高度</text>
          <input
            class="dimension-input"
            type="number"
            value="{{targetHeight}}"
            bindinput="onHeightInput"
            placeholder="高度"
          />
          <text class="input-unit">px</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <button
        class="btn btn-primary btn-lg btn-block {{isProcessing ? 'btn-loading' : ''}}"
        bindtap="confirmResize"
        disabled="{{isProcessing}}"
      >
        <text wx:if="{{isProcessing}}">处理中...</text>
        <text wx:else>确认调整</text>
      </button>

      <button
        wx:if="{{resultPath}}"
        class="btn btn-secondary btn-lg btn-block"
        bindtap="saveToAlbum"
      >
        保存到相册
      </button>
    </view>
  </view>

  <!-- Canvas -->
  <canvas type="2d" id="previewCanvas" class="hidden-canvas"></canvas>
  <canvas type="2d" id="resizeCanvas" class="hidden-canvas"></canvas>

  <view class="safe-area-bottom"></view>
</view>

<!--resize.wxml-->
<view class="resize-container">
  <!-- 未选择图片状态 -->
  <image-upload
    wx:if="{{!hasImage}}"
    icon="📐"
    title="选择图片"
    hint="支持证件照、考试报名等常用尺寸"
    bind:upload="chooseImage"
  />

  <!-- 已选择图片 -->
  <view wx:else class="resize-layout">
    <!-- 图片预览区域（带尺寸标注） -->
    <view class="preview-section">
      <view class="preview-header">
        <text class="preview-title">尺寸预览</text>
        <view class="change-btn" bindtap="chooseImage">
          <text>更换</text>
        </view>
      </view>

      <view class="preview-with-dimensions">
        <view class="preview-main">
          <!-- 高度标注（在图片左侧） -->
          <view class="dimension-height-wrapper">
            <view class="dimension-height" style="height: {{previewDisplayHeight}}px;">
              <view class="dimension-line-v"></view>
              <text class="dimension-text-v">{{targetHeight}} px</text>
              <view class="dimension-line-v"></view>
            </view>
          </view>

          <view class="preview-content">
            <!-- 宽度标注（在图片上方） -->
            <view class="dimension-width" style="width: {{previewDisplayWidth}}px;">
              <view class="dimension-line"></view>
              <text class="dimension-text">{{targetWidth}} px</text>
              <view class="dimension-line"></view>
            </view>

            <!-- 图片容器 -->
            <view class="preview-container" style="width: {{previewDisplayWidth}}px; height: {{previewDisplayHeight}}px;">
              <image
                wx:if="{{previewPath}}"
                class="preview-image"
                src="{{previewPath}}"
                mode="aspectFit"
              />
              <view wx:if="{{!previewPath}}" class="preview-loading">
                <text>生成预览中...</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 尺寸预设选择（横向滑动） -->
    <scroll-selector
      title="常用尺寸"
      list="{{presetSizes}}"
      selectedId="{{selectedPreset}}"
      showHint="{{true}}"
      hintText="左右滑动查看更多"
      bind:select="onPresetSelect"
    />

    <!-- 自定义尺寸 -->
    <view class="custom-section">
      <view class="custom-header">
        <text class="custom-title">自定义尺寸</text>
        <view class="aspect-ratio-toggle">
          <text class="toggle-label">锁定比例</text>
          <switch
            class="toggle-switch"
            checked="{{maintainAspectRatio}}"
            bindchange="onAspectRatioChange"
            color="var(--accent)"
          />
        </view>
      </view>

      <view class="dimension-inputs">
        <view class="input-group">
          <text class="input-label">宽度</text>
          <input
            class="dimension-input"
            type="number"
            value="{{targetWidth}}"
            bindchange="onWidthChange"
            placeholder="宽度"
          />
          <text class="input-unit">px</text>
        </view>

        <view class="dimension-separator">×</view>

        <view class="input-group">
          <text class="input-label">高度</text>
          <input
            class="dimension-input"
            type="number"
            value="{{targetHeight}}"
            bindchange="onHeightChange"
            placeholder="高度"
          />
          <text class="input-unit">px</text>
        </view>
      </view>
    </view>

    <!-- 输出格式 -->
    <format-selector
      value="{{fileType}}"
      mode="horizontal"
      showDesc="{{false}}"
      bind:change="onFormatChange"
    />

    <!-- 操作按钮：始终显示重置+保存 -->
    <action-buttons
      isLoading="{{isProcessing}}"
      bind:reset="resetResize"
      bind:save="saveToAlbum"
    />
  </view>

  <!-- Canvas -->
  <canvas type="2d" id="previewCanvas" class="hidden-canvas"></canvas>
  <canvas type="2d" id="resizeCanvas" class="hidden-canvas"></canvas>

  <view class="safe-area-bottom"></view>
</view>

/* collage.wxss */
/* 拼图拼接页面样式 */

.container {
  padding: 20rpx 30rpx;
  padding-bottom: 200rpx;
}

/* 区块样式 */
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: #f5f5f7;
  border-radius: 12rpx;
  border: 2rpx dashed #c7c7cc;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #1d1d1f;
  font-weight: 500;
}

.empty-subtext {
  font-size: 24rpx;
  color: #86868b;
  margin-top: 8rpx;
}

/* 图片列表 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: calc((100% - 48rpx) / 4);
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f7;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
}

.image-index {
  position: absolute;
  bottom: 4rpx;
  left: 4rpx;
  width: 32rpx;
  height: 32rpx;
  background: rgba(0, 102, 255, 0.8);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 500;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #c7c7cc;
  background: #fafafa;
}

.add-icon {
  font-size: 48rpx;
  color: #86868b;
  font-weight: 300;
}

/* 布局选择 */
.layout-scroll {
  white-space: nowrap;
}

.layout-list {
  display: inline-flex;
  gap: 16rpx;
}

.layout-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f5f7;
  border-radius: 12rpx;
  min-width: 120rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.layout-item.active {
  background: var(--accent-light);
  border-color: var(--accent);
}

.layout-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  line-height: 1.2;
  white-space: pre-line;
  text-align: center;
}

.layout-name {
  font-size: 22rpx;
  color: #1d1d1f;
}

.layout-item.active .layout-name {
  color: var(--accent);
  font-weight: 500;
}

/* 设置项 */
.setting-item {
  margin-bottom: 24rpx;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.setting-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #1d1d1f;
  margin-bottom: 16rpx;
}

.setting-value {
  color: var(--accent);
  font-weight: 500;
  font-size: 26rpx;
}

.setting-slider {
  margin: 0;
}

/* 颜色选择 */
.color-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.color-item.active {
  border-color: var(--accent);
}

.color-check {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

/* 预览区域 */
.preview-area {
  position: relative;
  background: #f5f5f7;
  border-radius: 12rpx;
  overflow: hidden;
}

.result-image {
  width: 100%;
  display: block;
}

.preview-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  color: #fff;
  font-size: 24rpx;
  text-align: center;
}

/* 底部占位 */
.bottom-space {
  height: 40rpx;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  margin: 0;
  padding: 0;
}

.action-btn::after {
  display: none;
}

.action-btn.primary {
  background: var(--accent);
  color: #ffffff;
}

.action-btn.primary.disabled {
  background: #c7c7cc;
}

.action-btn.secondary {
  background: #f5f5f7;
  color: var(--accent);
  border: 2rpx solid var(--accent);
}

/* 隐藏 Canvas */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}

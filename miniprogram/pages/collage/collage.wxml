<!--collage.wxml-->
<view class="container">
  <!-- 图片选择区域 -->
  <view class="section">
    <view class="section-title">选择图片</view>

    <!-- 未选择图片状态 -->
    <image-upload
      wx:if="{{!hasImages}}"
      icon="🖼️"
      title="点击选择图片"
      hint="最多支持 {{currentLayout.maxImages}} 张图片"
      bind:upload="chooseImages"
    />

    <!-- 已选择图片列表 -->
    <view wx:else class="image-list">
      <view
        wx:for="{{images}}"
        wx:key="index"
        class="image-item"
        data-index="{{index}}"
        bindtap="replaceImage"
      >
        <image class="preview-img" src="{{item}}" mode="aspectFill" />
        <view class="remove-btn" data-index="{{index}}" catchtap="removeImage">×</view>
        <view class="image-index">{{index + 1}}</view>
      </view>

      <!-- 添加按钮 -->
      <view
        wx:if="{{images.length < currentLayout.maxImages}}"
        class="image-item add-btn"
        bindtap="addImages"
      >
        <view class="add-icon">+</view>
      </view>
    </view>
  </view>

  <!-- 布局选择 -->
  <view class="section">
    <scroll-selector
      title="布局模板"
      list="{{layoutTemplates}}"
      selectedId="{{currentLayout.id}}"
      showHint="{{true}}"
      hintText="左右滑动查看更多"
      bind:select="onLayoutSelect"
    />
  </view>

  <!-- 样式设置 -->
  <view class="section">
    <view class="section-title">样式设置</view>

    <!-- 间距 -->
    <slider-control
      label="图片间距"
      value="{{spacing}}"
      min="0"
      max="50"
      unit="px"
      activeColor="#41bc3f"
      bind:change="onSpacingChange"
    />

    <!-- 圆角 -->
    <slider-control
      label="圆角大小"
      value="{{borderRadius}}"
      min="0"
      max="50"
      unit="px"
      activeColor="#41bc3f"
      bind:change="onRadiusChange"
    />

    <!-- 背景色 -->
    <color-picker
      title="背景颜色"
      colors="{{colorList}}"
      selectedColor="{{backgroundColor}}"
      showTitle="{{true}}"
      bind:select="onColorSelect"
    />
  </view>

  <!-- 输出设置 -->
  <view class="section">
    <view class="section-title">输出设置</view>

    <!-- 输出宽度 -->
    <slider-control
      label="输出宽度"
      value="{{outputWidth}}"
      min="600"
      max="2400"
      step="100"
      unit="px"
      activeColor="#41bc3f"
      bind:change="onWidthChange"
    />

    <!-- 画质 -->
    <slider-control
      label="输出画质"
      value="{{outputQuality}}"
      min="60"
      max="100"
      unit="%"
      activeColor="#41bc3f"
      bind:change="onQualityChange"
    />
    <view class="quality-tip" wx:if="{{fileType === 'png'}}">
      <text class="tip-text">提示：PNG为无损格式，画质设置仅对JPG有效</text>
    </view>
  </view>

  <!-- 输出格式 -->
  <format-selector
    value="{{fileType}}"
    mode="horizontal"
    showDesc="{{false}}"
    bind:change="onFormatChange"
  />

  <!-- 预览区域 -->
  <view wx:if="{{showPreview && resultPath}}" class="section">
    <image-preview
      imagePath="{{resultPath}}"
      title="预览效果"
      showChange="{{false}}"
      isProcessing="{{isProcessing}}"
      processingText="生成中..."
      bind:preview="previewImage"
    />
  </view>

  <!-- 操作按钮 -->
  <action-buttons
    hasResult="{{true}}"
    isLoading="{{isProcessing}}"
    disabled="{{!hasImages}}"
    primaryText="保存到相册"
    secondaryText="重置"
    saveText="保存到相册"
    loadingText="处理中..."
    bind:primary="saveToAlbum"
    bind:secondary="resetCollage"
    bind:save="saveToAlbum"
  />

  <!-- 底部占位 -->
  <view class="bottom-space"></view>
</view>

<!-- 隐藏的 Canvas -->
<canvas type="2d" id="collageCanvas" class="hidden-canvas"></canvas>

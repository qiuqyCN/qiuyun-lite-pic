/**convert.wxss**/

.container {
  min-height: 100vh;
  background: #F8F9FA;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder {
  text-align: center;
  padding: 40rpx;
}

.icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 60rpx;
}

.back-btn {
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: white;
  border-radius: 50rpx;
  padding: 24rpx 80rpx;
  font-size: 32rpx;
  border: none;
}

.back-btn::after {
  border: none;
}

<!--convert.wxml-->
<view class="convert-container">
  <!-- 未选择图片状态 -->
  <image-upload
    wx:if="{{!hasImage}}"
    icon="+"
    title="选择图片"
    hint="支持多种格式导入，可转为 JPG、PNG"
    bind:upload="chooseImage"
  />

  <!-- 已选择图片 -->
  <view wx:else class="convert-layout">
    <!-- 图片预览区域 -->
    <image-preview
      imagePath="{{convertedPath || imagePath}}"
      title="{{convertedPath ? '转换完成' : '图片预览'}}"
      showChange="{{true}}"
      isProcessing="{{isProcessing}}"
      processingText="转换中..."
      bind:change="chooseImage"
      bind:preview="previewImage"
    />

    <!-- 格式信息 -->
    <view class="format-section">
      <view class="format-info">
        <view class="format-row">
          <text class="format-label">原格式</text>
          <view class="format-badge original">
            <text class="format-text">{{originalFormat}}</text>
          </view>
          <text class="format-size">{{originalSize}} KB</text>
        </view>
        <view wx:if="{{convertedPath}}" class="format-arrow">
          <text class="arrow-icon">↓</text>
        </view>
        <view wx:if="{{convertedPath}}" class="format-row">
          <text class="format-label">转换后</text>
          <view class="format-badge converted">
            <text class="format-text">{{convertedFormat}}</text>
          </view>
          <text class="format-size">{{convertedSize}} KB</text>
        </view>
      </view>
    </view>

    <!-- 转换设置 -->
    <view class="settings-section">
      <!-- 目标格式选择 -->
      <format-selector
        value="{{targetFormat}}"
        mode="vertical"
        title="目标格式"
        showTip="{{true}}"
        tipText="PNG支持透明背景，JPG文件更小。灰色选项为原图格式，不可选择"
        disabledFormats="{{disabledFormats}}"
        bind:change="onFormatChange"
      />

      <!-- 质量设置（仅JPG显示） -->
      <view wx:if="{{targetFormat !== 'png'}}" class="quality-control">
        <view class="quality-header">
          <text class="quality-label">输出质量</text>
          <text class="quality-value">{{quality}}%</text>
        </view>
        <slider
          class="quality-slider"
          min="60"
          max="100"
          value="{{quality}}"
          block-size="24"
          activeColor="#41bc3f"
          backgroundColor="#e8e8ed"
          bindchange="onQualityChange"
        />
        <view class="quality-hints">
          <text>文件更小</text>
          <text>画质更好</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮：始终显示重置+保存 -->
    <action-buttons
      hasResult="{{true}}"
      isLoading="{{isProcessing}}"
      primaryText="保存到相册"
      secondaryText="重置"
      saveText="保存到相册"
      loadingText="处理中..."
      bind:primary="saveToAlbum"
      bind:secondary="resetConvert"
      bind:save="saveToAlbum"
    />
  </view>

  <!-- 隐藏Canvas -->
  <canvas
    type="2d"
    id="convertCanvas"
    class="hidden-canvas"
  ></canvas>

  <view class="safe-area-bottom"></view>
</view>

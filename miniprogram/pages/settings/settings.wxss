/* settings.wxss - 现代极简风格 */

.page-container {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 0 30rpx;
  box-sizing: border-box;
}

/* Header */
.page-header {
  padding: 60rpx 0 40rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1d1d1f;
}

/* Section */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #86868b;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Settings Card */
.settings-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* Setting Item */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  transition: background 0.15s ease;
}

.setting-item:active {
  background: #f9f9f9;
}

.setting-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.cache-icon {
  background: #fff2f0;
}

.feedback-icon {
  background: #e6f7ff;
}

.about-icon {
  background: #f6ffed;
}

.icon {
  font-size: 36rpx;
}

.setting-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.setting-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1d1d1f;
}

.setting-desc {
  font-size: 24rpx;
  color: #86868b;
}

.setting-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cache-size {
  font-size: 26rpx;
  color: #86868b;
}

.arrow {
  font-size: 32rpx;
  color: #c7c7cc;
  font-weight: 300;
}

/* Divider */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 24rpx;
}

/* Footer */
.page-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.logo-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.version {
  font-size: 24rpx;
  color: #86868b;
  margin-bottom: 12rpx;
}

.slogan {
  font-size: 24rpx;
  color: #c7c7cc;
}

/* Safe Area */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

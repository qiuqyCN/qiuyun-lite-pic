<!--settings.wxml-->
<view class="page-container">
  <!-- Header -->
  <view class="page-header">
    <text class="header-title">设置</text>
  </view>

  <!-- General Settings -->
  <view class="section">
    <view class="section-title">通用</view>
    <view class="settings-card">
      <view class="setting-item" bindtap="onClearCache">
        <view class="setting-left">
          <view class="icon-wrapper cache-icon">
            <text class="icon">🗑️</text>
          </view>
          <view class="setting-info">
            <text class="setting-name">清除缓存</text>
            <text class="setting-desc">释放存储空间</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="cache-size">{{cacheSize}}</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- About -->
  <view class="section">
    <view class="section-title">关于</view>
    <view class="settings-card">
      <view class="setting-item" bindtap="onFeedback">
        <view class="setting-left">
          <view class="icon-wrapper feedback-icon">
            <text class="icon">💬</text>
          </view>
          <view class="setting-info">
            <text class="setting-name">意见反馈</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="arrow">›</text>
        </view>
      </view>
      
      <view class="divider"></view>
      
      <view class="setting-item" bindtap="onAbout">
        <view class="setting-left">
          <view class="icon-wrapper about-icon">
            <text class="icon">ℹ️</text>
          </view>
          <view class="setting-info">
            <text class="setting-name">关于我们</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Footer -->
  <view class="page-footer">
    <view class="logo-section">
      <image class="logo-img" src="/images/logo.png" mode="aspectFit"/>
      <text class="app-name">秋云轻图</text>
    </view>
    <text class="version">Version 1.0.0</text>
    <text class="slogan">轻点之间，美图呈现</text>
  </view>

  <view class="safe-area-bottom"></view>
</view>

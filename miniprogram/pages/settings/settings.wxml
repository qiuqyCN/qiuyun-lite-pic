<!--settings.wxml-->
<view class="page-container">
  <!-- Header -->
  <view class="page-header">
    <text class="header-title">设置</text>
    <text class="header-description">管理您的偏好设置</text>
  </view>

  <!-- Processing Settings -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">处理设置</text>
    </view>
    
    <view class="settings-list">
      <view class="setting-row">
        <view class="setting-content">
          <text class="setting-label">默认压缩质量</text>
          <text class="setting-description">设置图片压缩的默认质量</text>
        </view>
        <view class="setting-control">
          <slider 
            class="quality-slider" 
            min="10" 
            max="100" 
            value="{{defaultQuality}}"
            block-size="20"
            activeColor="#0f172a"
            backgroundColor="#e2e8f0"
            show-value
            bindchange="onQualityChange"
          />
        </view>
      </view>

      <view class="setting-row">
        <view class="setting-content">
          <text class="setting-label">自动保存到相册</text>
          <text class="setting-description">处理完成后自动保存</text>
        </view>
        <view class="setting-control">
          <switch 
            checked="{{autoSave}}"
            color="#0f172a"
            bindchange="onAutoSaveChange"
          />
        </view>
      </view>
    </view>
  </view>

  <!-- Storage Settings -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">存储管理</text>
    </view>
    
    <view class="settings-list">
      <view class="setting-row setting-row-clickable" bindtap="onClearCache">
        <view class="setting-content">
          <text class="setting-label">清除缓存</text>
          <text class="setting-description">释放存储空间</text>
        </view>
        <view class="setting-control">
          <text class="setting-value">{{cacheSize}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- About -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">关于</text>
    </view>
    
    <view class="settings-list">
      <view class="setting-row setting-row-clickable" bindtap="onFeedback">
        <view class="setting-content">
          <text class="setting-label">意见反馈</text>
        </view>
        <view class="setting-control">
          <text class="setting-arrow">›</text>
        </view>
      </view>
      
      <view class="setting-row setting-row-clickable" bindtap="onAbout">
        <view class="setting-content">
          <text class="setting-label">关于我们</text>
        </view>
        <view class="setting-control">
          <text class="setting-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Footer -->
  <view class="page-footer">
    <text class="footer-title">秋云轻图</text>
    <text class="footer-version">版本 1.0.0</text>
    <text class="footer-description">轻点之间，美图呈现</text>
  </view>

  <view class="safe-area-bottom"></view>
</view>

/* rotate.wxss */
/* 图片旋转/翻转页面样式 */

.container {
  padding: 20rpx 30rpx;
  padding-bottom: 200rpx;
}

/* 区块样式 */
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 24rpx;
}

/* 旋转选择 */
.rotation-list {
  display: flex;
  gap: 16rpx;
}

.rotation-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #f5f5f7;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.rotation-item.active {
  background: rgba(65, 188, 63, 0.1);
  border-color: #41bc3f;
}

.rotation-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  color: #1d1d1f;
}

.rotation-item.active .rotation-icon {
  color: #41bc3f;
}

.rotation-label {
  font-size: 24rpx;
  color: #1d1d1f;
}

.rotation-item.active .rotation-label {
  color: #41bc3f;
  font-weight: 500;
}

/* 翻转选择 */
.flip-list {
  display: flex;
  gap: 16rpx;
}

.flip-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #f5f5f7;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.flip-item.active {
  background: rgba(65, 188, 63, 0.1);
  border-color: #41bc3f;
}

.flip-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  color: #1d1d1f;
}

.flip-item.active .flip-icon {
  color: #41bc3f;
}

.flip-label {
  font-size: 24rpx;
  color: #1d1d1f;
}

.flip-item.active .flip-label {
  color: #41bc3f;
  font-weight: 500;
}

/* 隐藏Canvas */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}

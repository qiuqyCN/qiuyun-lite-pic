/* crop.wxss */
/* 图片裁剪页面样式 */

.container {
  padding: 20rpx 30rpx;
  padding-bottom: 200rpx;
}

/* 区块样式 */
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 24rpx;
}

/* 裁剪区域区块 */
.crop-section {
  margin-top: 30rpx;
}

/* 裁剪区域 */
.crop-area {
  position: relative;
  margin: 0 auto;
  overflow: hidden;
  background: #f5f5f7;
  border-radius: 12rpx;
  touch-action: none;
}

.crop-image {
  display: block;
}

/* 裁剪框 */
.crop-frame {
  position: absolute;
  border: 4rpx solid #41bc3f;
  box-sizing: border-box;
}

.crop-frame-inner {
  width: 100%;
  height: 100%;
  border: 2rpx dashed rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
}

/* 调整大小的手柄 */
.resize-handle {
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  background: #41bc3f;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  z-index: 10;
}

.resize-handle.tl {
  top: -16rpx;
  left: -16rpx;
}

.resize-handle.tr {
  top: -16rpx;
  right: -16rpx;
}

.resize-handle.bl {
  bottom: -16rpx;
  left: -16rpx;
}

.resize-handle.br {
  bottom: -16rpx;
  right: -16rpx;
}

.crop-hint {
  text-align: center;
  font-size: 24rpx;
  color: #86868b;
  margin-top: 16rpx;
}

/* 比例选择 */
.ratio-scroll {
  white-space: nowrap;
}

.ratio-list {
  display: inline-flex;
  gap: 16rpx;
}

.ratio-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  background: #f5f5f7;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.ratio-item.active {
  background: rgba(65, 188, 63, 0.1);
  border-color: #41bc3f;
}

.ratio-label {
  font-size: 26rpx;
  color: #1d1d1f;
}

.ratio-item.active .ratio-label {
  color: #41bc3f;
  font-weight: 500;
}

/* 隐藏Canvas */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}

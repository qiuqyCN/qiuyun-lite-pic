.qrcode-container {
  padding: 20px;
  background: #f5f5f7;
  min-height: 100vh;
  padding-bottom: calc(20px + env(safe-area-inset-bottom));
}

.section {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 12px;
}

/* 输入区域 */
.input-textarea {
  width: 100%;
  height: 100px;
  background: #f5f5f7;
  border-radius: 12px;
  padding: 12px;
  font-size: 15px;
  color: #1d1d1f;
  box-sizing: border-box;
}

.input-field {
  width: 100%;
  height: 48px;
  background: #f5f5f7;
  border-radius: 12px;
  padding: 0 14px;
  font-size: 15px;
  color: #1d1d1f;
  margin-bottom: 10px;
  box-sizing: border-box;
}

.input-field:last-child {
  margin-bottom: 0;
}

/* Picker */
.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 48px;
  background: #f5f5f7;
  border-radius: 12px;
  padding: 0 14px;
  margin-bottom: 10px;
}

.picker-label {
  font-size: 15px;
  color: #1d1d1f;
}

.picker-value {
  font-size: 15px;
  color: #41bc3f;
  font-weight: 500;
}

.picker-value-inline {
  font-size: 14px;
  color: #41bc3f;
  font-weight: 500;
  padding: 6px 12px;
  background: #f5f5f7;
  border-radius: 8px;
}

/* 更多参数 */
.more-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4px 0;
}

.more-title {
  font-size: 14px;
  font-weight: 600;
  color: #1d1d1f;
}

.more-arrow {
  font-size: 20px;
  color: #c7c7cc;
  transition: transform 0.3s ease;
}

.more-arrow.up {
  transform: rotate(90deg);
}

.more-arrow.down {
  transform: rotate(0deg);
}

/* 参数行 */
.param-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid #f5f5f7;
}

.param-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.param-label {
  font-size: 14px;
  color: #1d1d1f;
  flex-shrink: 0;
}

/* 颜色选择 */
.color-options {
  display: flex;
  gap: 10px;
  align-items: center;
}

.color-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid transparent;
  transition: all 0.2s ease;
}

.color-dot.active {
  border-color: #41bc3f;
  transform: scale(1.15);
  box-shadow: 0 0 0 2px rgba(65, 188, 63, 0.3);
}

/* Logo */
.logo-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo-preview-wrap {
  position: relative;
  width: 40px;
  height: 40px;
}

.logo-preview {
  width: 40px;
  height: 40px;
  border-radius: 8px;
}

.logo-remove {
  position: absolute;
  top: -6px;
  right: -6px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #ff3b30;
  color: white;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.logo-add {
  padding: 6px 14px;
  background: #f5f5f7;
  border-radius: 8px;
  font-size: 13px;
  color: #41bc3f;
  font-weight: 500;
}

/* 滑块 */
.slider-wrap {
  flex: 1;
  margin-left: 12px;
}

/* 预览区域 */
.preview-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px 0;
  min-height: 220px;
  position: relative;
}

.qrcode-canvas {
  width: 200px;
  height: 200px;
}

.preview-placeholder {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.placeholder-icon {
  font-size: 48px;
  opacity: 0.3;
}

.placeholder-text {
  font-size: 14px;
  color: #c7c7cc;
}
/* history.wxss - 现代极简风格 */

.page-container {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 0 24px;
  box-sizing: border-box;
}

/* Header */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32px 0 24px;
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.header-title {
  font-size: 32px;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.header-count {
  font-size: 14px;
  color: #86868b;
  font-weight: 400;
}

.clear-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 18px;
  background: #ffffff;
  border-radius: 20px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.clear-btn:active {
  transform: scale(0.96);
  opacity: 0.8;
}

.clear-btn.disabled {
  opacity: 0.4;
}

.clear-icon {
  font-size: 16px;
}

.clear-text {
  font-size: 14px;
  color: #ff4d4f;
  font-weight: 500;
}

/* History Container */
.history-container {
  padding-bottom: 32px;
}

/* History List */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* History Item - 滑动容器 */
.history-item-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 16px;
}

.history-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  transition: transform 0.2s ease;
  position: relative;
  z-index: 1;
}

.history-item:active {
  transform: scale(0.98);
  background: #fafafa;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 80px;
  background: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 16px 16px 0;
  z-index: 0;
}

.delete-text {
  color: #ffffff;
  font-size: 14px;
  font-weight: 500;
}

/* Image Wrapper */
.image-wrapper {
  position: relative;
  width: 72px;
  height: 72px;
  border-radius: 12px;
  overflow: hidden;
  flex-shrink: 0;
  background: #f5f5f7;
}

.history-thumb {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
}

.type-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 4px 0;
  font-size: 10px;
  text-align: center;
  font-weight: 600;
  color: #ffffff;
}

/* History Info */
.history-info {
  flex: 1;
  margin-left: 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-width: 0;
}

.info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-time {
  font-size: 15px;
  color: #1d1d1f;
  font-weight: 600;
}

.history-relative-time {
  font-size: 12px;
  color: #86868b;
  font-weight: 400;
}

/* Params Tags */
.params-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.tag {
  font-size: 11px;
  color: #86868b;
  background: #f5f5f7;
  padding: 4px 10px;
  border-radius: 6px;
  font-weight: 500;
}

.tag-primary {
  background: #e8f5e9;
  color: #41bc3f;
}

.tag-success {
  background: #e3f2fd;
  color: #1976d2;
}

.tag-warning {
  background: #fff3e0;
  color: #f57c00;
}

/* Arrow */
.arrow {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8px;
}

.arrow-icon {
  font-size: 20px;
  color: #c7c7cc;
  font-weight: 300;
}

/* List Footer */
.list-footer {
  text-align: center;
  padding: 32px 0;
}

.footer-text {
  font-size: 13px;
  color: #c7c7cc;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120px 48px;
  text-align: center;
}

.empty-illustration {
  margin-bottom: 32px;
}

.empty-circle {
  width: 140px;
  height: 140px;
  background: linear-gradient(135deg, #e8f4f8 0%, #f0e8f4 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.empty-icon {
  font-size: 56px;
  line-height: 1;
}

.empty-title {
  font-size: 22px;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 8px;
  letter-spacing: -0.01em;
}

.empty-desc {
  font-size: 15px;
  color: #86868b;
  margin-bottom: 32px;
  line-height: 1.5;
}

.empty-action {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  background: var(--accent, #41bc3f);
  border-radius: 24px;
  box-shadow: 0 4px 12px rgba(65, 188, 63, 0.3);
  transition: all 0.2s ease;
}

.empty-action:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.action-text {
  font-size: 16px;
  color: #ffffff;
  font-weight: 600;
}

.action-arrow {
  font-size: 16px;
  color: #ffffff;
}

/* Safe Area */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* history.wxss - 现代极简风格 */

.page-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding: 0 24rpx;
  box-sizing: border-box;
}

/* Header */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.2;
}

.header-count {
  font-size: 26rpx;
  color: #999;
  font-weight: 400;
}

.clear-btn {
  padding: 16rpx 32rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 10;
}

.clear-btn:active {
  opacity: 0.8;
}

.clear-text {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: 500;
}

/* History Container */
.history-container {
  padding-bottom: 40rpx;
}

/* History List */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s ease;
}

.history-item:active {
  transform: scale(0.98);
}

.image-wrapper {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.history-thumb {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
}

.type-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx 0;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  font-weight: 500;
}

.history-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-time {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.history-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.arrow {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* List Footer */
.list-footer {
  text-align: center;
  padding: 48rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #bbb;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
  text-align: center;
}

.empty-illustration {
  margin-bottom: 48rpx;
}

.empty-circle {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #e8f4f8 0%, #f0e8f4 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 80rpx;
  line-height: 200rpx;
  background: transparent;
  text-align: center;
  display: block;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.empty-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 48rpx;
  background: #0066ff;
  border-radius: 48rpx;
}

.action-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.action-arrow {
  font-size: 30rpx;
  color: #fff;
}

/* Safe Area */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

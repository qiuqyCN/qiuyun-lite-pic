<!--history.wxml-->
<view class="page-container">
  <!-- Header -->
  <view class="page-header">
    <text class="header-title">处理历史</text>
    <text class="header-description">查看您处理过的图片</text>
  </view>

  <!-- History List -->
  <view wx:if="{{historyList.length > 0}}">
    <view class="history-list">
      <view 
        class="history-item" 
        wx:for="{{historyList}}" 
        wx:key="id"
        data-item="{{item}}"
        bindtap="onHistoryTap"
      >
        <image class="history-thumb" src="{{item.resultPath}}" mode="aspectFill"/>
        <view class="history-content">
          <text class="history-type">{{item.typeName}}</text>
          <text class="history-time">{{item.timeStr}}</text>
        </view>
        <text class="history-arrow">›</text>
      </view>
    </view>
    
    <view class="clear-section">
      <button class="btn btn-outline btn-block" bindtap="onClearHistory">
        清除历史记录
      </button>
    </view>
  </view>
  
  <!-- Empty State -->
  <view wx:else class="empty-state">
    <view class="empty-icon-wrapper">
      <text class="empty-icon">📷</text>
    </view>
    <text class="empty-title">暂无处理记录</text>
    <text class="empty-description">快去处理图片吧</text>
  </view>

  <view class="safe-area-bottom"></view>
</view>

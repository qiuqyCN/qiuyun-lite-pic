/* colorpicker.wxss */
/* 图片取色页面样式 - 增强版 */

.container {
  padding: 20rpx 30rpx;
  padding-bottom: 200rpx;
}

/* 区块样式 */
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.picker-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 24rpx;
}

/* 画布容器 */
.canvas-wrapper {
  position: relative;
  background: #f5f5f7;
  border-radius: 12rpx;
  overflow: hidden;
}

.color-canvas {
  display: block;
}

.canvas-hint {
  text-align: center;
  font-size: 24rpx;
  color: #86868b;
  margin-top: 16rpx;
}

/* 放大镜 */
.magnifier {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  overflow: hidden;
  pointer-events: none;
  transform: translate(-50%, -50%);
  z-index: 100;
}

.magnifier-canvas {
  width: 100%;
  height: 100%;
}

/* 取色结果 */
.color-result {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.color-preview {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  border: 4rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.favorite-icon {
  font-size: 40rpx;
  color: #ffffff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.color-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.color-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
  font-family: 'Courier New', monospace;
}

.color-format {
  font-size: 24rpx;
  color: #86868b;
}

.copy-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 24rpx;
  background: rgba(65, 188, 63, 0.1);
  border-radius: 12rpx;
  gap: 8rpx;
}

.copy-icon {
  font-size: 36rpx;
}

.copy-text {
  font-size: 24rpx;
  color: #41bc3f;
  font-weight: 500;
}

/* 历史记录 */
.history-scroll {
  white-space: nowrap;
}

.history-list {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 30rpx;
}

.history-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  border: 4rpx solid #e5e5e5;
  flex-shrink: 0;
}

/* 收藏颜色 */
.favorite-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.favorite-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  border: 4rpx solid #e5e5e5;
}

.favorite-empty {
  width: 100%;
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #86868b;
}

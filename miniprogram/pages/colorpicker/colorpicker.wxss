/* colorpicker.wxss */
/* 图片取色页面样式 */

.container {
  padding: 20rpx 30rpx;
  padding-bottom: 200rpx;
}

/* 区块样式 */
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 24rpx;
}

/* 画布容器 */
.canvas-wrapper {
  position: relative;
  display: flex;
  justify-content: center;
}

.color-canvas {
  max-width: 100%;
  max-height: 400rpx;
  background: #f5f5f7;
  border-radius: 12rpx;
}

.canvas-hint {
  text-align: center;
  font-size: 24rpx;
  color: #86868b;
  margin-top: 16rpx;
}

/* 放大镜 */
.magnifier {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #41bc3f;
  background: rgba(255, 255, 255, 0.9);
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 10;
}

.magnifier-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx dashed rgba(65, 188, 63, 0.5);
}

/* 取色结果 */
.color-result {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f7;
  border-radius: 12rpx;
}

.color-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e5e5e5;
  margin-right: 24rpx;
}

.color-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.color-hex {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  font-family: monospace;
}

.color-rgb {
  font-size: 24rpx;
  color: #86868b;
  margin-top: 4rpx;
  font-family: monospace;
}

.copy-hint {
  font-size: 24rpx;
  color: #41bc3f;
}

/* components/guide-popup/guide-popup.wxss */
.guide-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding-top: 120rpx;
}

.guide-popup {
  position: relative;
  width: 620rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.2);
}

/* 箭头 */
.popup-arrow {
  position: absolute;
  top: -18rpx;
  right: 100rpx;
  width: 36rpx;
  height: 36rpx;
  background: #ffffff;
  transform: rotate(45deg);
  box-shadow: -4rpx -4rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 标题 */
.popup-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1d1d1f;
  text-align: center;
  margin-bottom: 28rpx;
  line-height: 1.4;
}

/* 步骤列表 */
.step-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.step-number {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.6;
}

.step-highlight {
  font-size: 26rpx;
  color: #41bc3f;
  font-weight: 500;
  line-height: 1.6;
}

.step-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 2rpx 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666666;
  letter-spacing: 4rpx;
  margin-left: 4rpx;
}

/* 引导图片 */
.tip-image-wrapper {
  padding: 16rpx 0 8rpx;
  display: flex;
  justify-content: center;
}

.tip-image {
  width: 100%;
  border-radius: 12rpx;
}

/* 按钮区域 */
.popup-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.confirm-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #c94b00;
  transition: opacity 0.2s ease;
}

.confirm-btn:active {
  opacity: 0.85;
}

.never-show-btn {
  width: 180rpx;
  height: 88rpx;
  background: #f5f5f7;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #86868b;
  transition: opacity 0.2s ease;
}

.never-show-btn:active {
  opacity: 0.7;
}

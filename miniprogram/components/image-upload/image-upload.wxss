/* components/image-upload/image-upload.wxss */

.upload-section {
  padding: 20rpx 30rpx;
}

/* 头部标题和描述 */
.upload-header {
  margin-bottom: 30rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 16rpx;
}

.header-desc {
  display: block;
  font-size: 28rpx;
  color: #86868b;
}

/* 上传卡片 */
.upload-card {
  background: #ffffff;
  border-radius: 20rpx;
  border: 2rpx dashed #d2d2d7;
  padding: 100rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  transition: all 0.2s ease;
}

.upload-card:active {
  border-color: #41bc3f;
  background: #f8f9ff;
}

.upload-card.disabled {
  opacity: 0.6;
  pointer-events: none;
}

.upload-icon-box {
  width: 100rpx;
  height: 100rpx;
  background: #f5f5f7;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  color: #86868b;
  font-weight: 300;
  line-height: 1;
}

.upload-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.upload-hint {
  font-size: 26rpx;
  color: #86868b;
}

/* 底部说明区域 */
.upload-footer {
  margin-top: 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

/* 广告容器 */
.ad-container {
  margin-top: 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  overflow: hidden;
}

.ad-card {
  width: 100%;
  display: block;
}

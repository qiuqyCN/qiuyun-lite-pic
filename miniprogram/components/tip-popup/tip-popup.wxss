/* components/tip-popup/tip-popup.wxss */
.tip-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  z-index: 9999;
  display: flex;
  justify-content: flex-end;
  align-items: flex-start;
  padding-top: 88rpx;
  padding-right: 30rpx;
}

.tip-popup {
  position: relative;
  width: 560rpx;
  background: #1d1d1f;
  border-radius: 20rpx;
  overflow: visible;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.3);
}

/* 箭头 - 指向右上角 */
.popup-arrow {
  position: absolute;
  top: -16rpx;
  right: 60rpx;
  width: 32rpx;
  height: 32rpx;
  background: #1d1d1f;
  transform: rotate(45deg);
}

/* 内容区域 */
.popup-content {
  padding: 28rpx 24rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}

.popup-icon {
  font-size: 36rpx;
}

.popup-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.4;
}

.popup-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
}

/* 按钮区域 */
.popup-actions {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 24rpx 24rpx;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 68rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  transition: opacity 0.2s ease;
}

.action-btn:active {
  opacity: 0.7;
}

.confirm-btn {
  background: #41bc3f;
  color: #fff;
}

.never-show-btn {
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.9);
}

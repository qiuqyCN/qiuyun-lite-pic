/* 容器样式 */
.image-preview-container {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 标题栏样式 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.change-btn {
  background-color: #07c160;
  color: #ffffff;
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
}

/* 图片区域样式 */
.image-wrapper {
  position: relative;
  width: 100%;
  height: 400rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f7f7f7;
  border-radius: 12rpx;
  overflow: hidden;
}

/* 图片加载占位 */
.image-loading-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: #f7f7f7;
  z-index: 5;
}

.loading-spinner {
  width: 50rpx;
  height: 50rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 预览图片样式 - 带淡入动画 */
.preview-image {
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.3s ease-in-out;
}

.preview-image.loaded {
  opacity: 1;
}

.placeholder {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  height: 100%;
}

.placeholder-text {
  color: #999999;
  font-size: 28rpx;
}

/* 处理中遮罩样式 - 带过渡动画 */
.processing-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 10;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.2s ease-in-out, visibility 0.2s ease-in-out;
}

.processing-overlay.show {
  opacity: 1;
  visibility: visible;
}

.processing-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transform: scale(0.9);
  transition: transform 0.2s ease-in-out;
}

.processing-overlay.show .processing-content {
  transform: scale(1);
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #ffffff;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.processing-text {
  color: #ffffff;
  font-size: 28rpx;
}

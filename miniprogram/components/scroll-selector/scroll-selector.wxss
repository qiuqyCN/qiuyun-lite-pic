/* components/scroll-selector/scroll-selector.wxss */

.scroll-selector {
  padding: 20rpx 0;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 标题栏 */
.selector-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.selector-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}

/* 滑动提示 */
.scroll-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.scroll-hint-text {
  font-size: 24rpx;
  color: #86868b;
}

.scroll-hint-icon {
  font-size: 24rpx;
  color: #41bc3f;
  animation: scrollHint 1.5s ease-in-out infinite;
}

@keyframes scrollHint {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(4rpx); }
}

/* 滚动区域 */
.selector-scroll {
  white-space: nowrap;
}

.selector-list {
  display: inline-flex;
  padding: 0 30rpx;
  gap: 20rpx;
}

/* 选项项 */
.selector-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  min-width: 120rpx;
}

.selector-item:active {
  transform: scale(0.95);
}

.selector-item.active {
  border-color: #41bc3f;
  background: rgba(65, 188, 63, 0.1);
}

/* 默认内容样式 */
.item-default {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.item-icon {
  font-size: 48rpx;
}

.item-name {
  font-size: 26rpx;
  color: #1d1d1f;
  font-weight: 500;
  white-space: nowrap;
}

.item-size {
  font-size: 22rpx;
  color: #86868b;
  white-space: nowrap;
}

.selector-item.active .item-name {
  color: #41bc3f;
}

.selector-item.active .item-size {
  color: #41bc3f;
  opacity: 0.8;
}

/* components/color-picker/color-picker.wxss */

.color-picker {
  padding: 20rpx 0;
}

/* 标题 */
.picker-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 20rpx;
  padding: 0 30rpx;
}

/* 颜色网格 */
.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 30rpx;
}

/* 颜色项 */
.color-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  border: 4rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.color-item:active {
  transform: scale(0.9);
}

.color-item.active {
  border-color: #41bc3f;
  transform: scale(1.1);
}

/* 选中标记 */
.check-mark {
  width: 36rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 24rpx;
  color: #41bc3f;
  font-weight: bold;
}

/* 当前颜色显示 */
.current-color {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 30rpx;
  padding: 20rpx 30rpx;
  background: #f5f5f7;
  border-radius: 16rpx;
  margin-left: 30rpx;
  margin-right: 30rpx;
}

.color-label {
  font-size: 28rpx;
  color: #86868b;
}

.color-preview {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e5e5e5;
}

.color-value {
  font-size: 28rpx;
  color: #1d1d1f;
  font-family: monospace;
}

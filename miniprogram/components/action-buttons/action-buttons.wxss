/* components/action-buttons/action-buttons.wxss */

.action-buttons {
  padding: 20rpx 30rpx;
}

/* 按钮基础样式 */
.btn {
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  transition: all 0.2s ease;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #41bc3f 0%, #34a853 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(65, 188, 63, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(65, 188, 63, 0.2);
}

.btn-secondary {
  background: #f5f5f7;
  color: #1d1d1f;
}

.btn-secondary:active {
  background: #e8e8ed;
}

/* 大按钮 */
.btn-lg {
  padding: 28rpx 0;
  font-size: 34rpx;
}

/* 块级按钮 */
.btn-block {
  width: 100%;
}

/* 弹性按钮 */
.btn-flex {
  flex: 1;
  padding: 24rpx 0;
}

/* 按钮行布局 */
.action-row {
  display: flex;
  gap: 20rpx;
}

/* 加载状态 */
.btn-loading {
  opacity: 0.8;
}

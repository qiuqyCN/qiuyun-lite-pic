/* components/action-buttons/action-buttons.wxss */

.action-buttons {
  padding: 10px 15px;
}

/* 按钮行布局 */
.action-row {
  display: flex;
  gap: 10px;
}

/* 按钮基础样式 */
.btn {
  flex: 1;
  padding: 12px 0;
  font-size: 16px;
  font-weight: 600;
  border-radius: 8px;
  border: none;
  transition: all 0.2s ease;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #41bc3f 0%, #34a853 100%);
  color: #ffffff;
  box-shadow: 0 4px 12px rgba(65, 188, 63, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2px 6px rgba(65, 188, 63, 0.2);
}

.btn-secondary {
  background: #f5f5f7;
  color: #1d1d1f;
}

.btn-secondary:active {
  background: #e8e8ed;
}

/* 禁用状态 */
.btn-disabled {
  opacity: 0.5;
}

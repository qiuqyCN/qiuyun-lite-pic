<!--components/action-buttons/action-buttons.wxml-->
<view class="action-buttons">
  <view class="action-row">
    <button 
      class="btn btn-secondary {{isLoading ? 'btn-disabled' : ''}}"
      bindtap="onResetTap"
      disabled="{{isLoading}}"
    >
      {{resetText}}
    </button>
    <button 
      class="btn btn-primary {{isLoading || disabled ? 'btn-disabled' : ''}}"
      bindtap="onSaveTap"
      disabled="{{isLoading || disabled}}"
    >
      <text wx:if="{{isLoading}}">{{loadingText}}</text>
      <text wx:else>{{saveText}}</text>
    </button>
  </view>
</view>

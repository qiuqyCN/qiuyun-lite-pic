/* components/more-apps/more-apps.wxss */
.more-apps-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #86868b;
  font-weight: 500;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.apps-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  justify-content: space-around;
  gap: 16rpx;
}

.app-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  transition: background 0.2s ease;
}

.app-item:active {
  background: #f5f5f7;
}

.app-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
}

.app-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1d1d1f;
  line-height: 1.3;
}

.app-desc {
  font-size: 20rpx;
  color: #86868b;
  line-height: 1.3;
}
